Q1 :Palindrome Number
class Solution {
    public boolean isPalindrome(int x) {
        int n = x;
        int num = 0;
        while(x>0){
        int digit = x%10;
        num = num*10 + digit;
        x/=10;
        }
        if(n == num){
            return true;
        }
        else{
            return false;
        }
        
        
    }
}

